# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram user id of the admin who can access admin actions
ADMIN_ID=123456789

# Optional database URL
DB_URL=sqlite+aiosqlite:///./umkovo_v2.db

# Optional support/admin url shown to users
ADMIN_URL=https://t.me/umkovo_support

# Optional LLM settings (GigaChat only)
LLM_MODEL=
# leave empty to use default: https://gigachat.devices.sberbank.ru/api/v1
LLM_BASE_URL=
LLM_TIMEOUT_S=35
LLM_INSECURE_SSL=0

# GigaChat auth
# either Basic <base64(client_id:client_secret)> or raw client_id:client_secret
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
